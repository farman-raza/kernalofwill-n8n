FROM n8nio/n8n:latest

USER root

# Create data directory with proper permissions
RUN mkdir -p /data && chown -R node:node /data

# Switch back to node user
USER node

# Set environment variables
ENV N8N_PORT=8080
ENV N8N_PROTOCOL=https
ENV NODE_ENV=production

# Expose port
EXPOSE 8080

# Start n8n
CMD ["n8n", "start"]
